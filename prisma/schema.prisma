generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Report {
  id           String    @id @default(cuid())
  slug         String    @unique
  clientName   String
  clientEmail  String?
  passwordHash      String
  clientPasswordPlain String?
  isActive      Boolean   @default(true)
  viewCount     Int       @default(0)
  lastViewedAt  DateTime?
  clientProfile Json?
  adminProfile  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sections  ReportSection[]
  documents ClientDocument[]
  comments  PortalComment[]
  events    PortalEvent[]
  sessions  PortalSession[]

  @@map("reports")
}

model PortalComment {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  context   String   @default("general") // "general" | "section:<id>" | "doc:<id>"
  author    String
  text      String
  createdAt DateTime @default(now())

  @@index([reportId])
  @@map("portal_comments")
}

model PortalEvent {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  eventType String   // "tab_view" | "doc_open" | "section_expand" | "comment_add" | "file_submit"
  meta      Json?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([eventType])
  @@map("portal_events")
}

model PortalSession {
  id            String   @id @default(cuid())
  reportId      String
  report        Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sessionId     String   @unique
  ip            String?
  country       String?
  countryCode   String?
  city          String?
  device        String?
  browser       String?
  totalDuration Int      @default(0)
  startedAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())

  @@index([reportId])
  @@map("portal_sessions")
}

model ReportSection {
  id           String   @id @default(cuid())
  reportId     String
  sectionType  String
  title        String
  content      Json
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_sections")
}

model ClientDocument {
  id         String   @id @default(cuid())
  reportId   String
  docType    String
  title      String
  url        String
  notes      String?
  uploadedAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  tags         String[]
  imageUrl     String?
  liveUrl      String?
  stats        Json?
  featured     Boolean  @default(false)
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("projects")
}

model Testimonial {
  id           String   @id @default(cuid())
  clientName   String
  role         String?
  company      String?
  quote        String
  projectName  String?
  rating       Int      @default(5)
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("testimonials")
}

model Faq {
  id           String   @id @default(cuid())
  question     String
  answer       String
  category     String?
  displayOrder Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("faqs")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model SocialLink {
  id           String  @id @default(cuid())
  platform     String
  url          String
  handle       String?
  isVisible    Boolean @default(true)
  displayOrder Int     @default(0)

  @@map("social_links")
}

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  budget    String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_leads")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ─── New Client Portal Schema (v2) ───────────────────────────────────────────
// Old models (Report, ReportSection, ClientDocument, PortalComment,
// PortalEvent, PortalSession) are kept intact as backup above.

model Client {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  slug            String    @unique  // portal URL slug, e.g. "kruti-lunawat"
  passwordHash    String
  passwordPlain   String?   // stored for admin reference only
  isActive        Boolean   @default(true)
  clientProfile   Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  projects        ClientProject[]

  @@map("clients")
}

model ClientProject {
  id            String    @id @default(cuid())
  clientId      String
  name          String    // e.g. "Shopify Store Build — Phase 1"
  clientType    String    @default("new_build")  // new_build | existing_optimisation | audit_only | retainer | landing_page | migration
  status        String    @default("active")     // draft | active | completed
  tabConfig     Json?     // null = use clientType defaults
  adminProfile  Json      @default("{}")          // proposalVisible, notes, etc.
  displayOrder  Int       @default(0)
  viewCount     Int       @default(0)
  lastViewedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sections      ProjectSection[]
  documents     ProjectDocument[]
  comments      ProjectComment[]
  events        ProjectEvent[]
  sessions      ProjectSession[]

  @@map("client_projects")
}

model ProjectSection {
  id           String        @id @default(cuid())
  projectId    String
  sectionType  String
  title        String
  content      Json          @default("{}")
  displayOrder Int           @default(0)
  createdAt    DateTime      @default(now())
  project      ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_sections")
}

model ProjectDocument {
  id         String        @id @default(cuid())
  projectId  String
  docType    String
  title      String
  url        String
  notes      String?
  uploadedAt DateTime      @default(now())
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_documents")
}

model ProjectComment {
  id        String        @id @default(cuid())
  projectId String
  context   String        @default("general")
  author    String
  text      String
  createdAt DateTime      @default(now())
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_comments")
}

model ProjectEvent {
  id        String        @id @default(cuid())
  projectId String
  eventType String
  meta      Json          @default("{}")
  sessionId String?
  createdAt DateTime      @default(now())
  project   ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_events")
}

model ProjectDocumentLog {
  id         String   @id @default(cuid())
  projectId  String
  documentId String
  action     String   // 'added' | 'url_changed' | 'note_edited' | 'deleted'
  actorType  String   // 'admin' | 'client'
  docTitle   String?
  meta       Json?    // { oldValue?, newValue?, docType? }
  createdAt  DateTime @default(now())

  @@map("project_document_logs")
}

model ProjectSession {
  id            String        @id @default(cuid())
  projectId     String
  sessionId     String        @unique
  ip            String?
  country       String?
  countryCode   String?
  city          String?
  device        String?
  browser       String?
  totalDuration Int           @default(0)
  startedAt     DateTime      @default(now())
  lastActiveAt  DateTime      @default(now())
  project       ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_sessions")
}
