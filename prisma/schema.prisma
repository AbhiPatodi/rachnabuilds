generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Report {
  id           String    @id @default(cuid())
  slug         String    @unique
  clientName   String
  clientEmail  String?
  passwordHash String
  isActive     Boolean   @default(true)
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sections  ReportSection[]
  documents ClientDocument[]

  @@map("reports")
}

model ReportSection {
  id           String   @id @default(cuid())
  reportId     String
  sectionType  String
  title        String
  content      Json
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_sections")
}

model ClientDocument {
  id         String   @id @default(cuid())
  reportId   String
  docType    String
  title      String
  url        String
  notes      String?
  uploadedAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  tags         String[]
  imageUrl     String?
  liveUrl      String?
  stats        Json?
  featured     Boolean  @default(false)
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("projects")
}

model Testimonial {
  id           String   @id @default(cuid())
  clientName   String
  role         String?
  company      String?
  quote        String
  projectName  String?
  rating       Int      @default(5)
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("testimonials")
}

model Faq {
  id           String   @id @default(cuid())
  question     String
  answer       String
  category     String?
  displayOrder Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("faqs")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model SocialLink {
  id           String  @id @default(cuid())
  platform     String
  url          String
  handle       String?
  isVisible    Boolean @default(true)
  displayOrder Int     @default(0)

  @@map("social_links")
}

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  budget    String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_leads")
}
